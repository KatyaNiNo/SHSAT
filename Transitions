const LETTERS = ["A", "B", "C", "D"];

export default function TransitionsPractice() {
  const [currentQ, setCurrentQ] = useState(0);
  const [phase, setPhase] = useState("category"); // category | answer | feedback
  const [selectedCat, setSelectedCat] = useState(null);
  const [catCorrect, setCatCorrect] = useState(null);
  const [selectedAns, setSelectedAns] = useState(null);
  const [ansCorrect, setAnsCorrect] = useState(null);
  const [score, setScore] = useState(0);
  const [catScore, setCatScore] = useState(0);
  const [finished, setFinished] = useState(false);
  const [history, setHistory] = useState([]);
  const [showStart, setShowStart] = useState(true);
  const cardRef = useRef(null);

  const q = QUESTIONS[currentQ];

  useEffect(() => {
    if (cardRef.current) {
      cardRef.current.scrollTo({ top: 0, behavior: 'smooth' });
    }
  }, [currentQ, phase]);

  const handleCategoryPick = (catId) => {
    setSelectedCat(catId);
    const correct = catId === q.category;
    setCatCorrect(correct);
    if (correct) setCatScore(s => s + 1);
  };

  const proceedToAnswer = () => {
    setPhase("answer");
  };

  const handleAnswerPick = (idx) => {
    setSelectedAns(idx);
    const correct = idx === q.answer;
    setAnsCorrect(correct);
    if (correct) setScore(s => s + 1);
    setHistory(h => [...h, { id: q.id, catRight: selectedCat === q.category, ansRight: correct, answer: LETTERS[q.answer] }]);
    setPhase("feedback");
  };

  const nextQuestion = () => {
    if (currentQ + 1 >= QUESTIONS.length) {
      setFinished(true);
    } else {
      setCurrentQ(c => c + 1);
      setPhase("category");
      setSelectedCat(null);
      setCatCorrect(null);
      setSelectedAns(null);
      setAnsCorrect(null);
    }
  };

  const restart = () => {
    setCurrentQ(0);
    setPhase("category");
    setSelectedCat(null);
    setCatCorrect(null);
    setSelectedAns(null);
    setAnsCorrect(null);
    setScore(0);
    setCatScore(0);
    setFinished(false);
    setHistory([]);
    setShowStart(true);
  };

  const catObj = CATEGORIES.find(c => c.id === q.category);

  if (showStart) {
    return (
      <div style={{ minHeight: "100vh", background: "linear-gradient(135deg, #0e1f4d 0%, #1B3878 40%, #29ABE2 100%)", display: "flex", flexDirection: "column" }}>
        <Header />
        <div style={{ flex: 1, display: "flex", alignItems: "center", justifyContent: "center", padding: "24px" }}>
          <div style={{ background: "white", borderRadius: 20, padding: "48px 40px", maxWidth: 560, width: "100%", textAlign: "center", boxShadow: "0 20px 60px rgba(0,0,0,0.3)" }}>
            <div style={{ fontSize: 48, marginBottom: 16 }}>🔗</div>
            <h2 style={{ fontFamily: "'Georgia', serif", fontSize: 28, color: "#1B3878", margin: "0 0 12px" }}>Transitions Practice</h2>
            <p style={{ color: "#555", fontSize: 15, lineHeight: 1.7, margin: "0 0 28px" }}>
              13 questions from the March 2026 SAT. For each one, you will first identify the <strong>relationship</strong> between the two parts of the passage, then choose the best transition.
            </p>
            <div style={{ display: "flex", flexWrap: "wrap", gap: 10, justifyContent: "center", marginBottom: 32 }}>
              {CATEGORIES.map(c => (
                <span key={c.id} style={{ background: c.color + "18", color: c.color, fontWeight: 700, fontSize: 13, padding: "6px 14px", borderRadius: 20, border: `1.5px solid ${c.color}40` }}>
                  {c.emoji} {c.label}
                </span>
              ))}
            </div>
            <button onClick={() => setShowStart(false)} style={{ background: "#1B3878", color: "white", border: "none", borderRadius: 12, padding: "16px 48px", fontSize: 17, fontWeight: 700, cursor: "pointer", transition: "transform 0.15s", letterSpacing: 0.5 }}
              onMouseEnter={e => e.target.style.transform = "scale(1.04)"}
              onMouseLeave={e => e.target.style.transform = "scale(1)"}>
              Start Practice
            </button>
          </div>
        </div>
      </div>
    );
  }

  if (finished) {
    return (
      <div style={{ minHeight: "100vh", background: "linear-gradient(135deg, #0e1f4d 0%, #1B3878 40%, #29ABE2 100%)", display: "flex", flexDirection: "column" }}>
        <Header />
        <div style={{ flex: 1, display: "flex", alignItems: "flex-start", justifyContent: "center", padding: "32px 16px", overflowY: "auto" }}>
          <div style={{ background: "white", borderRadius: 20, padding: "40px 36px", maxWidth: 560, width: "100%", boxShadow: "0 20px 60px rgba(0,0,0,0.3)" }}>
            <div style={{ textAlign: "center", marginBottom: 28 }}>
              <div style={{ fontSize: 52, marginBottom: 8 }}>{score >= 11 ? "🏆" : score >= 8 ? "💪" : "📚"}</div>
              <h2 style={{ fontFamily: "'Georgia', serif", fontSize: 26, color: "#1B3878", margin: "0 0 6px" }}>Practice Complete!</h2>
              <p style={{ color: "#666", fontSize: 14, margin: 0 }}>Here is how you did:</p>
            </div>
            <div style={{ display: "flex", gap: 12, marginBottom: 24 }}>
              <ScoreBox label="Answers" value={score} total={13} color="#1B3878" />
              <ScoreBox label="Categories" value={catScore} total={13} color="#29ABE2" />
            </div>
            <div style={{ marginBottom: 24 }}>
              <h3 style={{ fontSize: 14, color: "#888", textTransform: "uppercase", letterSpacing: 1.5, margin: "0 0 12px", fontFamily: "sans-serif" }}>Results</h3>
              {history.map((h, i) => (
                <div key={i} style={{ display: "flex", alignItems: "center", gap: 10, padding: "8px 0", borderBottom: "1px solid #eee" }}>
                  <span style={{ background: "#1B3878", color: "white", fontWeight: 700, fontSize: 12, width: 28, height: 28, borderRadius: 6, display: "flex", alignItems: "center", justifyContent: "center", flexShrink: 0 }}>{h.id}</span>
                  <span style={{ fontSize: 20, flexShrink: 0 }}>{h.ansRight ? "✅" : "❌"}</span>
                  <span style={{ fontSize: 13, color: "#555", flex: 1 }}>
                    {h.ansRight ? "Correct" : `Answer: ${h.answer}`}
                    {h.catRight ? "" : " · Category missed"}
                  </span>
                </div>
              ))}
            </div>
            <button onClick={restart} style={{ width: "100%", background: "#1B3878", color: "white", border: "none", borderRadius: 12, padding: "14px", fontSize: 16, fontWeight: 700, cursor: "pointer" }}>
              Try Again
            </button>
          </div>
        </div>
      </div>
    );
  }

  return (
    <div style={{ minHeight: "100vh", background: "linear-gradient(135deg, #0e1f4d 0%, #1B3878 40%, #29ABE2 100%)", display: "flex", flexDirection: "column" }}>
      <Header />
      {/* Progress */}
      <div style={{ padding: "12px 20px 0" }}>
        <div style={{ display: "flex", alignItems: "center", gap: 8, maxWidth: 680, margin: "0 auto" }}>
          <span style={{ color: "rgba(255,255,255,0.8)", fontSize: 13, fontWeight: 600, fontFamily: "sans-serif", whiteSpace: "nowrap" }}>{currentQ + 1} / {QUESTIONS.length}</span>
          <div style={{ flex: 1, height: 6, background: "rgba(255,255,255,0.15)", borderRadius: 3, overflow: "hidden" }}>
            <div style={{ width: `${((currentQ + (phase === "feedback" ? 1 : 0)) / QUESTIONS.length) * 100}%`, height: "100%", background: "#29ABE2", borderRadius: 3, transition: "width 0.4s ease" }} />
          </div>
          <span style={{ color: "rgba(255,255,255,0.7)", fontSize: 12, fontFamily: "sans-serif", whiteSpace: "nowrap" }}>Score: {score}</span>
        </div>
      </div>

      {/* Main card */}
      <div style={{ flex: 1, display: "flex", alignItems: "flex-start", justifyContent: "center", padding: "16px 16px 32px" }}>
        <div ref={cardRef} style={{ background: "white", borderRadius: 20, maxWidth: 680, width: "100%", boxShadow: "0 20px 60px rgba(0,0,0,0.25)", overflow: "hidden", maxHeight: "calc(100vh - 140px)", overflowY: "auto" }}>
          {/* Question number bar */}
          <div style={{ background: "#f0f3f9", padding: "16px 28px", display: "flex", alignItems: "center", justifyContent: "space-between", borderBottom: "1px solid #e2e7f0" }}>
            <div style={{ display: "flex", alignItems: "center", gap: 12 }}>
              <span style={{ background: "#1A2263", color: "white", fontWeight: 700, fontSize: 16, width: 38, height: 38, borderRadius: 8, display: "flex", alignItems: "center", justifyContent: "center" }}>{q.id}</span>
              <span style={{ color: "#6B7280", fontSize: 14, fontFamily: "sans-serif" }}>Transition Question</span>
            </div>
            <PhaseIndicator phase={phase} />
          </div>

          {/* Passage */}
          <div style={{ padding: "24px 28px 20px" }}>
            <p style={{ fontSize: 14, color: "#888", textTransform: "uppercase", letterSpacing: 1.2, margin: "0 0 10px", fontWeight: 600, fontFamily: "sans-serif" }}>
              Which choice completes the text with the most logical transition?
            </p>
            <p style={{ fontSize: 16, color: "#333", lineHeight: 1.85, margin: 0, fontFamily: "'Georgia', serif" }}
              dangerouslySetInnerHTML={{ __html: q.body.replace("_____", '<span style="display:inline-block;width:60px;border-bottom:2.5px solid #29ABE2;margin:0 3px;vertical-align:middle"></span>') }} />
          </div>

          <div style={{ height: 1, background: "#e8ecf3", margin: "0 28px" }} />

          {/* Step 1: Category */}
          {phase === "category" && (
            <div style={{ padding: "24px 28px 28px" }}>
              <p style={{ fontSize: 15, fontWeight: 700, color: "#1B3878", margin: "0 0 6px", fontFamily: "sans-serif" }}>
                Step 1: What is the relationship?
              </p>
              <p style={{ fontSize: 13, color: "#777", margin: "0 0 16px", fontFamily: "sans-serif" }}>
                Read both parts of the passage. How does the second part connect to the first?
              </p>
              <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
                {CATEGORIES.map(cat => {
                  const isSelected = selectedCat === cat.id;
                  const showResult = selectedCat !== null;
                  const isCorrect = cat.id === q.category;
                  let bg = "white";
                  let border = `1.5px solid #d4d8e0`;
                  let opacity = 1;
                  if (showResult && isCorrect) { bg = cat.color + "12"; border = `2px solid ${cat.color}`; }
                  else if (showResult && isSelected && !isCorrect) { bg = "#fef2f2"; border = "2px solid #E63946"; }
                  else if (showResult) { opacity = 0.45; }

                  return (
                    <button key={cat.id} onClick={() => !showResult && handleCategoryPick(cat.id)}
                      disabled={showResult}
                      style={{ display: "flex", alignItems: "center", gap: 14, padding: "14px 18px", borderRadius: 14, border, background: bg, cursor: showResult ? "default" : "pointer", transition: "all 0.2s", opacity, textAlign: "left" }}>
                      <span style={{ fontSize: 22, flexShrink: 0 }}>{cat.emoji}</span>
                      <div style={{ flex: 1 }}>
                        <span style={{ fontWeight: 700, fontSize: 15, color: "#333", fontFamily: "sans-serif" }}>{cat.label}</span>
                        <span style={{ display: "block", fontSize: 12, color: "#888", marginTop: 2, fontFamily: "sans-serif" }}>{cat.desc}</span>
                      </div>
                      {showResult && isCorrect && <span style={{ fontSize: 18 }}>✅</span>}
                      {showResult && isSelected && !isCorrect && <span style={{ fontSize: 18 }}>❌</span>}
                    </button>
                  );
                })}
              </div>
              {selectedCat !== null && (
                <div style={{ marginTop: 16 }}>
                  <div style={{ background: catCorrect ? "#f0fdf4" : "#fef9ee", border: `1px solid ${catCorrect ? "#bbf7d0" : "#fde68a"}`, borderRadius: 12, padding: "14px 18px", marginBottom: 14 }}>
                    <p style={{ margin: 0, fontSize: 14, color: catCorrect ? "#166534" : "#92400e", fontFamily: "sans-serif", lineHeight: 1.6 }}>
                      {catCorrect
                        ? <><strong>Nice!</strong> This is a <strong>{catObj.label.toLowerCase()}</strong> relationship. Now pick the transition that fits.</>
                        : <><strong>Not quite.</strong> The relationship here is <strong>{catObj.label.toLowerCase()}</strong>: {catObj.desc.toLowerCase()}. Use that to find the right transition.</>
                      }
                    </p>
                  </div>
                  <button onClick={proceedToAnswer} style={{ width: "100%", background: "#1B3878", color: "white", border: "none", borderRadius: 12, padding: "14px", fontSize: 16, fontWeight: 700, cursor: "pointer", fontFamily: "sans-serif" }}>
                    Choose Your Answer →
                  </button>
                </div>
              )}
            </div>
          )}

          {/* Step 2: Answer */}
          {phase === "answer" && (
            <div style={{ padding: "24px 28px 28px" }}>
              <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 14 }}>
                <span style={{ background: catObj.color + "18", color: catObj.color, fontWeight: 700, fontSize: 12, padding: "4px 12px", borderRadius: 16, fontFamily: "sans-serif" }}>
                  {catObj.emoji} {catObj.label}
                </span>
                <p style={{ fontSize: 15, fontWeight: 700, color: "#1B3878", margin: 0, fontFamily: "sans-serif" }}>
                  Step 2: Pick the best transition
                </p>
              </div>
              <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
                {q.choices.map((choice, idx) => (
                  <button key={idx} onClick={() => handleAnswerPick(idx)}
                    style={{ display: "flex", alignItems: "center", gap: 16, padding: "16px 20px", borderRadius: 14, border: "1.5px solid #d4d8e0", background: "white", cursor: "pointer", transition: "all 0.15s", textAlign: "left" }}
                    onMouseEnter={e => { e.currentTarget.style.borderColor = "#1B3878"; e.currentTarget.style.background = "#f8faff"; }}
                    onMouseLeave={e => { e.currentTarget.style.borderColor = "#d4d8e0"; e.currentTarget.style.background = "white"; }}>
                    <span style={{ width: 34, height: 34, borderRadius: "50%", border: "1.5px solid #374151", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 14, fontWeight: 500, color: "#374151", flexShrink: 0, fontFamily: "sans-serif" }}>{LETTERS[idx]}</span>
                    <span style={{ fontSize: 16, color: "#333", fontFamily: "'Georgia', serif" }}>{choice}</span>
                  </button>
                ))}
              </div>
            </div>
          )}

          {/* Feedback */}
          {phase === "feedback" && (
            <div style={{ padding: "24px 28px 28px" }}>
              <div style={{ display: "flex", flexDirection: "column", gap: 10, marginBottom: 16 }}>
                {q.choices.map((choice, idx) => {
                  const isCorrectChoice = idx === q.answer;
                  const isSelectedChoice = idx === selectedAns;
                  let bg = "white";
                  let border = "1.5px solid #e5e7eb";
                  let opacity = 0.5;
                  let bubbleBg = "white";
                  let bubbleBorder = "#9ca3af";
                  let bubbleColor = "#9ca3af";

                  if (isCorrectChoice) {
                    bg = "#f0fdf4"; border = "2px solid #2FAF04"; opacity = 1;
                    bubbleBg = "#2FAF04"; bubbleBorder = "#2FAF04"; bubbleColor = "white";
                  } else if (isSelectedChoice && !ansCorrect) {
                    bg = "#fef2f2"; border = "2px solid #E63946"; opacity = 1;
                    bubbleBg = "#E63946"; bubbleBorder = "#E63946"; bubbleColor = "white";
                  }

                  return (
                    <div key={idx} style={{ display: "flex", alignItems: "center", gap: 16, padding: "16px 20px", borderRadius: 14, border, background: bg, opacity, transition: "all 0.3s" }}>
                      <span style={{ width: 34, height: 34, borderRadius: "50%", border: `2px solid ${bubbleBorder}`, background: bubbleBg, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 14, fontWeight: 700, color: bubbleColor, flexShrink: 0, fontFamily: "sans-serif" }}>
                        {isCorrectChoice ? "✓" : isSelectedChoice && !ansCorrect ? "✗" : LETTERS[idx]}
                      </span>
                      <span style={{ fontSize: 16, color: "#333", fontFamily: "'Georgia', serif" }}>{choice}</span>
                    </div>
                  );
                })}
              </div>
              <div style={{ background: ansCorrect ? "#f0fdf4" : "#fef2f2", border: `1px solid ${ansCorrect ? "#bbf7d0" : "#fecaca"}`, borderRadius: 12, padding: "16px 18px", marginBottom: 16 }}>
                <p style={{ margin: 0, fontSize: 14, color: ansCorrect ? "#166534" : "#991b1b", fontFamily: "sans-serif", lineHeight: 1.7 }}>
                  <strong>{ansCorrect ? "Correct! " : `The answer is ${LETTERS[q.answer]}. `}</strong>
                  {q.explanation}
                </p>
              </div>
              <button onClick={nextQuestion} style={{ width: "100%", background: "#1B3878", color: "white", border: "none", borderRadius: 12, padding: "14px", fontSize: 16, fontWeight: 700, cursor: "pointer", fontFamily: "sans-serif" }}>
                {currentQ + 1 >= QUESTIONS.length ? "See Results" : "Next Question →"}
              </button>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

function Header() {
  return (
    <div style={{ background: "rgba(0,0,0,0.2)", padding: "12px 20px", display: "flex", alignItems: "center", gap: 14, backdropFilter: "blur(8px)" }}>
      <img src={LOGO_SRC} alt="ivy tutors network" style={{ height: 42, width: "auto" }} />
      <div>
        <div style={{ color: "white", fontWeight: 700, fontSize: 16, fontFamily: "sans-serif", letterSpacing: 0.3 }}>Transitions Practice</div>
        <div style={{ color: "#29ABE2", fontSize: 11, fontFamily: "sans-serif" }}>ivy tutors network</div>
      </div>
    </div>
  );
}

function PhaseIndicator({ phase }) {
  const steps = [
    { key: "category", label: "Relationship" },
    { key: "answer", label: "Answer" },
    { key: "feedback", label: "Review" },
  ];
  const idx = steps.findIndex(s => s.key === phase);
  return (
    <div style={{ display: "flex", gap: 4, alignItems: "center" }}>
      {steps.map((s, i) => (
        <span key={s.key} style={{
          fontSize: 11, fontWeight: 700, fontFamily: "sans-serif",
          padding: "4px 10px", borderRadius: 10,
          background: i === idx ? "#1B3878" : i < idx ? "#29ABE2" : "#e5e7eb",
          color: i <= idx ? "white" : "#999",
          transition: "all 0.3s"
        }}>{s.label}</span>
      ))}
    </div>
  );
}

function ScoreBox({ label, value, total, color }) {
  const pct = Math.round((value / total) * 100);
  return (
    <div style={{ flex: 1, background: color + "08", border: `1.5px solid ${color}25`, borderRadius: 14, padding: "18px 16px", textAlign: "center" }}>
      <div style={{ fontSize: 36, fontWeight: 800, color, fontFamily: "sans-serif" }}>{value}<span style={{ fontSize: 18, color: "#aaa" }}>/{total}</span></div>
      <div style={{ fontSize: 12, color: "#888", fontFamily: "sans-serif", marginTop: 2 }}>{label} ({pct}%)</div>
    </div>
  );
}
